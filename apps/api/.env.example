# Copy this file to .env and fill in your values
# Everything runs on the same RunPod pod

# vLLM runs locally on the pod at port 8001
RUNPOD_API_BASE=http://localhost:8001/v1
RUNPOD_API_KEY=local
LLM_MODEL_NAME=tiiuae/Falcon-H1-7B-Instruct

# Qdrant — embedded mode (runs inside Python, no Docker needed)
QDRANT_PATH=/workspace/qdrant_storage
QDRANT_COLLECTION=menu_ar

# Embedding model (downloaded automatically on first run)
EMBEDDING_MODEL=BAAI/bge-m3

# Paths (relative to repo root)
MENU_JSON_PATH=data/menu.json
IMAGES_DIR=data/images
